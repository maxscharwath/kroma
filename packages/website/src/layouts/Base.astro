---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';
import { faq } from '../data/faq';

const ldSoftware = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'KROMA',
  operatingSystem: 'Linux, macOS, Windows, Synology DSM, Samsung Tizen, LG webOS, Android TV',
  applicationCategory: 'MultimediaApplication',
  description:
    'Self-hosted, direct-play, HEVC-first media streaming stack in a single Rust binary: requests, indexers, torrent engine, VPN kill switch, metadata and clients for web, desktop and TV.',
  url: `${site.url}/`,
  downloadUrl: site.releases,
  softwareVersion: site.version,
  license: site.license,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const ldFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a.replace(/<[^>]+>/g, '') },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{site.title}</title>
    <meta name="description" content={site.description} />
    <link rel="canonical" href={`${site.url}/`} />
    <meta name="theme-color" content="#0A0A0C" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="KROMA" />
    <meta property="og:title" content={site.title} />
    <meta
      property="og:description"
      content="Indexers, torrent engine, VPN kill switch, metadata and direct-play streaming to web, desktop and TV. One Rust binary. Zero video transcoding. MIT licensed."
    />
    <meta property="og:url" content={`${site.url}/`} />
    <meta property="og:image" content={`${site.url}/img/og.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={site.title} />
    <meta
      name="twitter:description"
      content="One Rust binary replaces the whole media stack: requests, indexers, torrents, VPN, metadata, playback. Self-hosted and MIT licensed."
    />
    <meta name="twitter:image" content={`${site.url}/img/og.jpg`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@62..125,300..900&family=Instrument+Serif:ital@1&family=JetBrains+Mono:wght@400..600&display=swap"
    />
    <link
      rel="preload"
      as="image"
      href="/img/home-1200.webp"
      imagesrcset="/img/home-1200.webp 1200w, /img/home-2200.webp 2200w"
      imagesizes="(max-width: 1300px) 94vw, 1200px"
      fetchpriority="high"
    />

    <script type="application/ld+json" set:html={JSON.stringify(ldSoftware)} />
    <script type="application/ld+json" set:html={JSON.stringify(ldFaq)} />
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <Header />
    <main><slot /></main>
    <Footer />
    <script>
      import '../scripts/interactions';
    </script>
  </body>
</html>
