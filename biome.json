{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/build",
      "!**/.tanstack",
      "!**/*.gen.ts",
      "!**/routeTree.gen.ts",
      "!**/*.template.html",
      "!clients/synology",
      "!server",
      "!clients/web/src/styles.css",
      "!packages/ui/src/tailwind.css",
      "!packages/tv/src/tv.css"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "noNestedTernary": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "overrides": [
    {
      "includes": [
        "packages/ui/src/**/*.ts",
        "packages/ui/src/**/*.tsx",
        "packages/tv/src/**/*.ts",
        "packages/tv/src/**/*.tsx",
        "!packages/**/*.web.ts",
        "!packages/**/*.web.tsx",
        "!packages/**/*.test.ts",
        "!packages/**/*.test.tsx",
        "!packages/ui/src/components/**",
        "!packages/tv/src/shared/preview/**",
        "!packages/tv/src/features/playback/player/avplayEngine.ts",
        "!packages/tv/src/features/playback/player/htmlEngine.ts",
        "!packages/tv/src/features/playback/player/useNowPlaying.ts",
        "!packages/tv/src/index.tsx",
        "!**/*.test.ts",
        "!**/*.test.tsx",
        "!**/preview/**",
        "!packages/ui/src/lib/dom.ts",
        "!packages/tv/src/shared/preview/cards.test.ts",
        "!packages/tv/src/shared/preview/deeplink.test.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedGlobals": {
              "level": "error",
              "options": {
                "deniedGlobals": {
                  "Audio": "Browser-only. React Native throws ReferenceError, which the runtime turns into SIGABRT. Add a `.web.ts` half and give the native side its own.",
                  "AudioContext": "Browser-only. Add a `.web.ts` half.",
                  "IntersectionObserver": "Browser-only. Grow from a measured scroll position instead (see @kroma/ui useGrowingCount).",
                  "MutationObserver": "Browser-only. Add a `.web.ts` half.",
                  "document": "Browser-only. React Native has no DOM: add a `.web.ts` half, or guard with `typeof document !== 'undefined'`.",
                  "getComputedStyle": "Browser-only. Measure with onLayout instead.",
                  "localStorage": "Browser-only. React Native has none: use the client's device store (see setSessionStorage).",
                  "matchMedia": "Browser-only. Use Platform / useWindowDimensions.",
                  "sessionStorage": "Browser-only. React Native has none.",
                  "window": "The worst one: React Native DEFINES `window` (it is `global`), so `typeof window !== 'undefined'` passes and `window.addEventListener` is then undefined rather than absent - \"undefined is not a function\", at render, on a TV. Use `webWindow()` from @kroma/ui/kit, or add a `.web.ts` half."
                }
              }
            }
          }
        }
      }
    }
  ],
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    }
  }
}
