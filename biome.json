{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/build",
      "!**/.tanstack",
      "!**/*.gen.ts",
      "!**/routeTree.gen.ts",
      "!**/*.template.html",
      "!clients/synology",
      "!server",
      "!clients/web/src/styles.css",
      "!packages/ui/src/tailwind.css",
      "!packages/tv/src/tv.css",
      "!packages/website/src/styles/global.css",
      "!**/*.astro",
      "!**/.astro"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "noNestedTernary": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/*.test.tsx"],
      "linter": {
        "rules": {
          "style": { "noNonNullAssertion": "off", "noNestedTernary": "off" },
          "suspicious": {
            "noExplicitAny": "off",
            "noApproximativeNumericConstant": "off",
            "noTemplateCurlyInString": "off"
          }
        }
      }
    }
  ],
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    }
  }
}
